# Optional environment variables for the alignment server.
# Export them in your shell (or set in the system environment) before `python app.py`.
# This app does not load a `.env` file unless you add tooling that does.

# Hugging Face Hub — some models used by WhisperX are gated or rate-limited; a token may be required.
# https://huggingface.co/docs/huggingface_hub/package_reference/environment_variables
# HF_TOKEN=

# Optional: which NVIDIA GPU(s) are visible (e.g. only the first card).
# CUDA_VISIBLE_DEVICES=0
